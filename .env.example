# ==========================================================================
# SpectraContent Intelligence OS — local development environment template
# Copy to `.env` and adjust. NEVER commit a real `.env` file.
# All values below are LOCAL DEVELOPMENT defaults only — not secrets.
# ==========================================================================

NODE_ENV=development

# --- PostgreSQL (docker compose service: postgres) ---
DATABASE_URL=postgresql://spectra:spectra_local_dev@localhost:5432/spectra?schema=public

# --- Redis (docker compose service: redis) ---
REDIS_URL=redis://localhost:6379

# --- Object storage (docker compose service: minio) ---
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=spectra-local
STORAGE_SECRET_KEY=spectra_local_dev
STORAGE_BUCKET=spectra-dev
STORAGE_FORCE_PATH_STYLE=true

# --- API ---
API_PORT=4000
API_HOST=0.0.0.0
# Comma-separated browser origins allowed for CORS and the CSRF origin check.
API_CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# --- Worker ---
WORKER_HEARTBEAT_INTERVAL_MS=30000
WORKER_CONCURRENCY=5

# --- Web ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# --- Logging ---
LOG_LEVEL=info
