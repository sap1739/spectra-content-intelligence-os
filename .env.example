# ==========================================================================
# SpectraContent Intelligence OS — local development environment template
# Copy to `.env` and adjust. NEVER commit a real `.env` file.
# All values below are LOCAL DEVELOPMENT defaults only — not secrets.
# ==========================================================================

NODE_ENV=development

# --- PostgreSQL (docker compose service: postgres) ---
DATABASE_URL=postgresql://spectra:spectra_local_dev@localhost:5432/spectra?schema=public

# --- Redis (docker compose service: redis) ---
REDIS_URL=redis://localhost:6379

# --- Object storage (docker compose service: minio) ---
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=spectra-local
STORAGE_SECRET_KEY=spectra_local_dev
STORAGE_BUCKET=spectra-dev
STORAGE_FORCE_PATH_STYLE=true

# --- API ---
API_PORT=4000
API_HOST=0.0.0.0
# Comma-separated browser origins allowed for CORS and the CSRF origin check.
API_CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# --- AI (Phase 3, optional) ---
# Leave ANTHROPIC_API_KEY unset to run with AI generation honestly disabled
# (draft endpoints return 503; the UI shows an "not configured" banner).
# When set, evidence-grounded content drafting is enabled (@spectra/ai-anthropic).
# ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_MAX_OUTPUT_TOKENS=4096

# --- Publishing (Phase 4, optional) ---
# Base64-encoded 32-byte AES-256-GCM key for sealing social-account credentials.
# The API seals credentials with it; the WORKER decrypts them to publish — set
# the SAME value in both processes. Unset => social targets can be registered
# but credentials cannot be stored (honestly refused) and WordPress publishing
# resolves to UNSUPPORTED. Generate one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# WordPress target: register the site URL as the account handle and the
# credential as "wp-username:application password" (WordPress 5.6+ app password).
# SOCIAL_TOKEN_ENCRYPTION_KEY=

# --- Worker ---
WORKER_HEARTBEAT_INTERVAL_MS=30000
WORKER_CONCURRENCY=5

# --- Web ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# --- Logging ---
LOG_LEVEL=info
