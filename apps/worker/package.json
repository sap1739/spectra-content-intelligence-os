{
  "name": "@spectra/worker",
  "version": "0.1.0",
  "private": true,
  "description": "Spectra background worker — queue-backed job execution with heartbeat.",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@spectra/ai-anthropic": "workspace:*",
    "@spectra/config": "workspace:*",
    "@spectra/content-pipeline": "workspace:*",
    "@spectra/database": "workspace:*",
    "@spectra/logging": "workspace:*",
    "@spectra/observability": "workspace:*",
    "@spectra/publishing": "workspace:*",
    "@spectra/research-pipeline": "workspace:*",
    "@spectra/security": "workspace:*",
    "@spectra/social-wordpress": "workspace:*",
    "@spectra/storage": "workspace:*",
    "@spectra/workflow-core": "workspace:*",
    "ioredis": "5.10.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.0"
  }
}
