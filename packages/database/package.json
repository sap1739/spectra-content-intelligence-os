{
  "name": "@spectra/database",
  "version": "0.1.0",
  "private": true,
  "description": "Prisma schema, migrations, tenant-scoped client helpers and seed data.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx src/seed.ts",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "@spectra/contracts": "workspace:*",
    "@spectra/knowledge-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "prisma": "^6.9.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.0"
  }
}
