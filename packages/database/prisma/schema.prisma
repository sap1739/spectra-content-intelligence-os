// SpectraContent Intelligence OS — Phase 1 foundational schema.
//
// Multi-tenancy: shared database, shared schema. Every tenant-owned table
// carries organizationId (billing boundary) and, where applicable,
// workspaceId (primary isolation boundary). Application code must always
// filter by tenant columns; see packages/database/src/tenant-guard.ts and
// docs/DATABASE_DESIGN.md.
//
// Conventions:
// - UUID primary keys generated by the database (pgcrypto gen_random_uuid).
// - All timestamps are timestamptz stored in UTC; user display timezones are
//   explicit columns (User.timezone, Workspace.timezone).
// - Soft deletion via deletedAt on user-facing entities; AuditLog is
//   append-only and never deleted.
// - The pgvector extension is enabled by migration for Phase 2 embeddings.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Identity & tenancy
// ---------------------------------------------------------------------------

enum UserStatus {
  INVITED
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

model User {
  id       String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email    String     @unique
  name     String
  /// IANA timezone for display purposes; storage is always UTC.
  timezone String     @default("UTC")
  locale   String     @default("en")
  status   UserStatus @default(ACTIVE)

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  memberships      Membership[]
  createdResearch  ResearchProject[] @relation("ResearchProjectCreatedBy")
  auditLogs        AuditLog[]
  credential       Credential?

  @@index([status])
  @@map("users")
}

/// Password credential, separated from User so future factors (passkeys,
/// TOTP) become sibling tables instead of columns. The hash embeds its own
/// scrypt parameters (see @spectra/security passwords.ts). NEVER logged.
model Credential {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @unique @db.Uuid
  passwordHash String
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credentials")
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  PENDING_DELETION
}

model Organization {
  id       String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug     String             @unique
  name     String
  status   OrganizationStatus @default(ACTIVE)
  settings Json               @default("{}")

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  memberships      Membership[]
  workspaces       Workspace[]
  brands           Brand[]
  verticals        CustomVertical[]
  researchProjects ResearchProject[]
  researchRuns     ResearchRun[]
  researchSources  ResearchSource[]
  researchFindings ResearchFinding[]
  trendCandidates  TrendCandidate[]
  auditLogs        AuditLog[]

  @@map("organizations")
}

enum MembershipRole {
  ORG_OWNER
  ORG_ADMIN
  WORKSPACE_ADMIN
  RESEARCHER
  CONTENT_STRATEGIST
  CREATOR
  DESIGNER
  EDITOR
  APPROVER
  PUBLISHER
  ANALYST
  CLIENT_REVIEWER
  READ_ONLY
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
}

model Membership {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String           @db.Uuid
  userId         String           @db.Uuid
  role           MembershipRole
  /// Explicit permission grants beyond the role bundle (permission strings).
  extraPermissions String[]       @default([])
  /// Optional restriction to specific workspaces; empty = all in org.
  workspaceIds   String[]         @default([]) @db.Uuid
  status         MembershipStatus @default(ACTIVE)
  invitedById    String?          @db.Uuid

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("memberships")
}

enum WorkspaceStatus {
  ACTIVE
  ARCHIVED
}

model Workspace {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String          @db.Uuid
  slug           String
  name           String
  description    String?
  /// Default display timezone for calendars; storage remains UTC.
  timezone       String          @default("UTC")
  settings       Json            @default("{}")
  status         WorkspaceStatus @default(ACTIVE)

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  brands           Brand[]
  verticals        CustomVertical[]
  researchProjects ResearchProject[]
  researchRuns     ResearchRun[]
  researchSources  ResearchSource[]
  researchFindings ResearchFinding[]
  trendCandidates  TrendCandidate[]

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@map("workspaces")
}

// ---------------------------------------------------------------------------
// Brand & custom vertical
// ---------------------------------------------------------------------------

enum BrandStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model Brand {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String      @db.Uuid
  workspaceId    String      @db.Uuid
  slug           String
  name           String
  description    String?
  websiteUrl     String?
  /// Brand voice: tone, personality, do-nots, example phrases.
  voice          Json?
  guidelines     Json        @default("{}")
  languages      String[]    @default([])
  status         BrandStatus @default(DRAFT)

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  researchProjects ResearchProject[]

  @@unique([workspaceId, slug])
  @@index([organizationId])
  @@index([workspaceId, status])
  @@map("brands")
}

enum VerticalStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

/// Fully user-defined vertical. Industry fields are free text on purpose —
/// no hard-coded industry list. Structured collections live in typed JSONB
/// validated by @spectra/contracts customVerticalSchema at the API boundary.
model CustomVertical {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String         @db.Uuid
  workspaceId    String         @db.Uuid
  slug           String
  name           String
  description    String?
  industry       String?
  subIndustry    String?
  businessModel  String?
  products       String[]       @default([])
  services       String[]       @default([])
  /// [{ name, description?, roles[], seniority? }]
  targetAudiences Json          @default("[]")
  customerPainPoints String[]   @default([])
  geographies    String[]       @default([])
  languages      String[]       @default([])
  /// [{ name, websiteUrl?, notes? }]
  competitors    Json           @default("[]")
  keywords       String[]       @default([])
  excludedKeywords String[]     @default([])
  trustedDomains String[]       @default([])
  blockedDomains String[]       @default([])
  preferredPublications String[] @default([])
  regulatoryConsiderations String[] @default([])
  /// [{ name, startMonth?, endMonth?, notes? }]
  seasonalEvents Json           @default("[]")
  commercialObjectives String[] @default([])
  contentObjectives String[]    @default([])
  preferredPlatforms String[]   @default([])
  /// [{ criterion, weight }] — brand-specific relevance criteria for scoring.
  relevanceCriteria Json        @default("[]")
  status         VerticalStatus @default(DRAFT)

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  researchProjects ResearchProject[]
  trendCandidates  TrendCandidate[]

  @@unique([workspaceId, slug])
  @@index([organizationId])
  @@index([workspaceId, status])
  @@map("custom_verticals")
}

// ---------------------------------------------------------------------------
// Research
// ---------------------------------------------------------------------------

enum ResearchProjectStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

model ResearchProject {
  id             String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String                @db.Uuid
  workspaceId    String                @db.Uuid
  verticalId     String?               @db.Uuid
  brandId        String?               @db.Uuid
  name           String
  description    String?
  /// The user's research objective in their own words.
  objective      String?
  status         ResearchProjectStatus @default(DRAFT)
  createdById    String?               @db.Uuid

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  vertical     CustomVertical? @relation(fields: [verticalId], references: [id], onDelete: SetNull)
  brand        Brand?          @relation(fields: [brandId], references: [id], onDelete: SetNull)
  createdBy    User?           @relation("ResearchProjectCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  runs          ResearchRun[]
  sources       ResearchSource[]
  findings      ResearchFinding[]
  trends        TrendCandidate[]
  claims        ExtractedClaim[]
  citations     Citation[]
  evidencePacks EvidencePack[]

  @@index([workspaceId, status])
  @@index([organizationId])
  @@map("research_projects")
}

enum ResearchRunStatus {
  PENDING
  QUEUED
  RUNNING
  SUCCEEDED
  PARTIALLY_SUCCEEDED
  FAILED
  CANCELLED
}

enum ResearchRunTrigger {
  MANUAL
  SCHEDULED
  API
}

model ResearchRun {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String             @db.Uuid
  workspaceId    String             @db.Uuid
  projectId      String             @db.Uuid
  status         ResearchRunStatus  @default(PENDING)
  trigger        ResearchRunTrigger @default(MANUAL)
  /// Planned queries: [{ providerKind, queryText, language?, geography? }]
  queryPlan      Json               @default("[]")
  currentStage   String?
  startedAt      DateTime?          @db.Timestamptz(6)
  completedAt    DateTime?          @db.Timestamptz(6)
  failureReason  String?
  /// { queriesPlanned, sourcesDiscovered, findingsExtracted, ... }
  stats          Json               @default("{}")
  createdById    String?            @db.Uuid

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project      ResearchProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  sources  ResearchSource[]
  findings ResearchFinding[]

  @@index([projectId, status])
  @@index([workspaceId, status])
  @@map("research_runs")
}

enum SourceCategory {
  WEB
  NEWS
  BLOG
  ACADEMIC
  SOCIAL
  VIDEO
  PODCAST
  COMMUNITY
  DOCUMENT
  INTERNAL
  OTHER
}

enum SourceProcessingStatus {
  DISCOVERED
  FETCHED
  EXTRACTED
  NORMALIZED
  DEDUPLICATED
  ANALYZED
  FAILED
  SKIPPED
}

model ResearchSource {
  id             String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String                 @db.Uuid
  workspaceId    String                 @db.Uuid
  projectId      String                 @db.Uuid
  runId          String?                @db.Uuid
  url            String
  canonicalUrl   String?
  /// SHA-256 of the normalized URL — exact-duplicate detection per workspace.
  urlHash        String
  title          String?
  publisher      String?
  author         String?
  publishedAt    DateTime?              @db.Timestamptz(6)
  retrievedAt    DateTime               @db.Timestamptz(6)
  language       String?
  geography      String?
  category       SourceCategory         @default(WEB)
  credibilityScore Float?
  freshnessScore Float?
  duplicateOfSourceId String?           @db.Uuid
  duplicateClusterKey String?
  /// SHA-256 of extracted content — near-duplicate clustering input.
  contentHash    String?
  /// { license?, rightsHolder?, attributionRequired?, usageNotes? }
  copyright      Json?
  /// { providerId, providerKind, requestRef?, retrievedAt, pipelineVersion? }
  provenance     Json
  processingStatus SourceProcessingStatus @default(DISCOVERED)
  metadata       Json                   @default("{}")

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project      ResearchProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  run          ResearchRun?    @relation(fields: [runId], references: [id], onDelete: SetNull)
  duplicateOf  ResearchSource? @relation("SourceDuplicates", fields: [duplicateOfSourceId], references: [id], onDelete: SetNull)
  duplicates   ResearchSource[] @relation("SourceDuplicates")

  findings  ResearchFinding[]
  snapshots SourceSnapshot[]

  @@unique([workspaceId, urlHash])
  @@index([projectId, processingStatus])
  @@index([workspaceId, category])
  @@index([duplicateClusterKey])
  @@map("research_sources")
}

/// Immutable capture of a source at retrieval time. Raw bytes live in
/// tenant-scoped object storage under `storageKey`; the row is the index.
model SourceSnapshot {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @db.Uuid
  workspaceId    String   @db.Uuid
  sourceId       String   @db.Uuid
  retrievedAt    DateTime @db.Timestamptz(6)
  /// SHA-256 of the captured content.
  contentHash    String
  storageKey     String
  mimeType       String
  sizeBytes      Int
  extractionStatus SnapshotExtractionStatus @default(PENDING)
  createdAt      DateTime @default(now()) @db.Timestamptz(6)

  source   ResearchSource    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  findings ResearchFinding[]

  @@index([sourceId])
  @@index([workspaceId, contentHash])
  @@map("source_snapshots")
}

enum SnapshotExtractionStatus {
  PENDING
  EXTRACTED
  FAILED
}

enum FindingStatus {
  PENDING_REVIEW
  VALIDATED
  REJECTED
  STALE
}

model ResearchFinding {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String         @db.Uuid
  workspaceId    String         @db.Uuid
  projectId      String         @db.Uuid
  runId          String?        @db.Uuid
  sourceId       String         @db.Uuid
  snapshotId     String?        @db.Uuid
  summary        String
  excerpt        String?
  /// { startOffset?, endOffset?, selector?, page? }
  excerptLocation Json?
  confidence     Float?
  credibilityScore Float?
  freshnessScore Float?
  language       String?
  geography      String?
  duplicateClusterKey String?
  sourceCategory SourceCategory @default(WEB)
  topics         String[]       @default([])
  entities       String[]       @default([])
  corroboratedByFindingIds String[] @default([]) @db.Uuid
  /// { license?, rightsHolder?, attributionRequired?, usageNotes? }
  copyright      Json?
  /// { providerId, providerKind, requestRef?, retrievedAt, pipelineVersion? }
  provenance     Json
  status         FindingStatus  @default(PENDING_REVIEW)
  processingStage String?

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project      ResearchProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  run          ResearchRun?    @relation(fields: [runId], references: [id], onDelete: SetNull)
  source       ResearchSource  @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  snapshot     SourceSnapshot? @relation(fields: [snapshotId], references: [id], onDelete: SetNull)
  citations    Citation[]

  @@index([projectId, status])
  @@index([sourceId])
  @@index([workspaceId, status])
  @@index([duplicateClusterKey])
  @@map("research_findings")
}

// ---------------------------------------------------------------------------
// Evidence layer: claims, citations, evidence packs, knowledge chunks
// ---------------------------------------------------------------------------

enum ClaimType {
  FACTUAL
  STATISTIC
  PREDICTION
  OPINION
  QUOTE
}

enum ClaimVerificationStatus {
  UNVERIFIED
  CORROBORATED
  DISPUTED
  VERIFIED
  REJECTED
}

/// Heuristically extracted claims (ADR-0016). One row per normalized claim
/// per project; corroboration = supported by ≥2 distinct sources.
model ExtractedClaim {
  id             String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String                  @db.Uuid
  workspaceId    String                  @db.Uuid
  projectId      String                  @db.Uuid
  text           String
  /// titleKey-normalized claim text — the per-project dedupe identity.
  normalizedKey  String
  claimType      ClaimType               @default(FACTUAL)
  verificationStatus ClaimVerificationStatus @default(UNVERIFIED)
  supportingFindingIds String[]          @default([]) @db.Uuid
  /// Distinct sources backing the claim (drives corroboration).
  sourceCount    Int                     @default(1)
  confidence     Float?

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  project   ResearchProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  citations Citation[]

  @@unique([projectId, normalizedKey])
  @@index([workspaceId, verificationStatus])
  @@map("extracted_claims")
}

/// First-class citation: finding ↔ source (+snapshot) with a byte locator.
/// The audit anchor behind every statement (ADR-0011).
model Citation {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @db.Uuid
  workspaceId    String    @db.Uuid
  projectId      String    @db.Uuid
  findingId      String    @db.Uuid
  sourceId       String    @db.Uuid
  snapshotId     String?   @db.Uuid
  claimId        String?   @db.Uuid
  url            String
  title          String?
  publisher      String?
  publishedAt    DateTime? @db.Timestamptz(6)
  retrievedAt    DateTime  @db.Timestamptz(6)
  excerpt        String?
  startOffset    Int?
  endOffset      Int?
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)

  project ResearchProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  finding ResearchFinding @relation(fields: [findingId], references: [id], onDelete: Cascade)
  claim   ExtractedClaim? @relation(fields: [claimId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([findingId])
  @@index([claimId])
  @@map("citations")
}

enum EvidencePackStatus {
  DRAFT
  READY
  STALE
  ARCHIVED
}

/// Curated bundle of findings/claims/citations per trend topic — the input
/// contract for content generation (Phase 3).
model EvidencePack {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String             @db.Uuid
  workspaceId      String             @db.Uuid
  projectId        String             @db.Uuid
  trendCandidateId String?            @db.Uuid
  topicKey         String
  title            String
  summary          String?
  status           EvidencePackStatus @default(DRAFT)
  findingIds       String[]           @default([]) @db.Uuid
  claimIds         String[]           @default([]) @db.Uuid
  citationIds      String[]           @default([]) @db.Uuid
  /// Forward lineage: which generated content consumed this pack.
  usedByContentItemIds String[]       @default([]) @db.Uuid

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  project ResearchProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, topicKey])
  @@index([workspaceId, status])
  @@map("evidence_packs")
}

/// Embedded knowledge chunks (pgvector, ADR-0005/0016). Phase 2 embeds
/// research findings (documentId = source id, metadata.kind marks it);
/// uploaded documents join in Phase 3. Vector ops via PgVectorStore raw SQL.
model DocumentChunk {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @db.Uuid
  workspaceId    String   @db.Uuid
  /// Collection isolates embedding models — one model per collection.
  collection     String
  documentId     String   @db.Uuid
  index          Int      @default(0)
  text           String
  metadata       Json     @default("{}")
  embeddingProvider String
  embeddingModel String
  dimensions     Int
  embedding      Unsupported("vector(256)")?

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([organizationId, workspaceId, collection])
  @@index([documentId])
  @@map("document_chunks")
}

enum TrendAlertType {
  STATE_CHANGE
  SCORE_THRESHOLD
  NEW_EVIDENCE
  RISK_FLAG
}

model TrendAlert {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String         @db.Uuid
  workspaceId      String         @db.Uuid
  trendCandidateId String         @db.Uuid
  alertType        TrendAlertType
  message          String
  triggeredAt      DateTime       @default(now()) @db.Timestamptz(6)
  acknowledgedAt   DateTime?      @db.Timestamptz(6)
  acknowledgedById String?        @db.Uuid

  trendCandidate TrendCandidate @relation(fields: [trendCandidateId], references: [id], onDelete: Cascade)

  @@index([workspaceId, acknowledgedAt])
  @@map("trend_alerts")
}

// ---------------------------------------------------------------------------
// Trend intelligence
// ---------------------------------------------------------------------------

enum TrendState {
  EMERGING
  ACCELERATING
  PEAKING
  STABLE
  DECLINING
  SEASONAL
  EVERGREEN
  UNVERIFIED
  REJECTED
}

model TrendCandidate {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String     @db.Uuid
  workspaceId    String     @db.Uuid
  projectId      String?    @db.Uuid
  verticalId     String?    @db.Uuid
  /// Stable identity for upserts within a project (e.g. normalized topic keyword).
  topicKey       String?
  title          String
  summary        String?
  state          TrendState @default(UNVERIFIED)
  /// Normalized [0,1] score from the latest scoring run.
  normalizedScore Float?
  /// Full TrendScoreResult (components + explanation) — always explainable.
  latestScore    Json?
  scoringConfigId String?
  scoringConfigVersion String?
  /// Trend signals referenced by this candidate.
  signals        Json       @default("[]")
  sourceIds      String[]   @default([]) @db.Uuid
  findingIds     String[]   @default([]) @db.Uuid
  firstSeenAt    DateTime?  @db.Timestamptz(6)
  lastSeenAt     DateTime?  @db.Timestamptz(6)

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project      ResearchProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  vertical     CustomVertical?  @relation(fields: [verticalId], references: [id], onDelete: SetNull)
  alerts       TrendAlert[]

  @@index([workspaceId, state])
  @@index([projectId, topicKey])
  @@index([workspaceId, normalizedScore])
  @@map("trend_candidates")
}

// ---------------------------------------------------------------------------
// Audit
// ---------------------------------------------------------------------------

enum AuditActorType {
  USER
  SYSTEM
  API_CLIENT
}

/// Append-only. Never updated, never soft-deleted. Sensitive values must be
/// redacted by @spectra/security deepRedact before insertion.
model AuditLog {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String         @db.Uuid
  workspaceId    String?        @db.Uuid
  actorType      AuditActorType @default(USER)
  actorUserId    String?        @db.Uuid
  action         String
  resourceType   String
  resourceId     String?
  correlationId  String?
  ip             String?
  userAgent      String?
  changes        Json?
  metadata       Json           @default("{}")
  createdAt      DateTime       @default(now()) @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUser    User?        @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([resourceType, resourceId])
  @@index([correlationId])
  @@map("audit_logs")
}
