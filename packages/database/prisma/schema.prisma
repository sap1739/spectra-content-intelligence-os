// SpectraContent Intelligence OS — Phase 1 foundational schema.
//
// Multi-tenancy: shared database, shared schema. Every tenant-owned table
// carries organizationId (billing boundary) and, where applicable,
// workspaceId (primary isolation boundary). Application code must always
// filter by tenant columns; see packages/database/src/tenant-guard.ts and
// docs/DATABASE_DESIGN.md.
//
// Conventions:
// - UUID primary keys generated by the database (pgcrypto gen_random_uuid).
// - All timestamps are timestamptz stored in UTC; user display timezones are
//   explicit columns (User.timezone, Workspace.timezone).
// - Soft deletion via deletedAt on user-facing entities; AuditLog is
//   append-only and never deleted.
// - The pgvector extension is enabled by migration for Phase 2 embeddings.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Identity & tenancy
// ---------------------------------------------------------------------------

enum UserStatus {
  INVITED
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

model User {
  id       String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email    String     @unique
  name     String
  /// IANA timezone for display purposes; storage is always UTC.
  timezone String     @default("UTC")
  locale   String     @default("en")
  status   UserStatus @default(ACTIVE)

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  memberships     Membership[]
  createdResearch ResearchProject[] @relation("ResearchProjectCreatedBy")
  auditLogs       AuditLog[]
  credential      Credential?

  @@index([status])
  @@map("users")
}

/// Password credential, separated from User so future factors (passkeys,
/// TOTP) become sibling tables instead of columns. The hash embeds its own
/// scrypt parameters (see @spectra/security passwords.ts). NEVER logged.
model Credential {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @unique @db.Uuid
  passwordHash String
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credentials")
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  PENDING_DELETION
}

model Organization {
  id       String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug     String             @unique
  name     String
  status   OrganizationStatus @default(ACTIVE)
  settings Json               @default("{}")

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  memberships      Membership[]
  workspaces       Workspace[]
  brands           Brand[]
  verticals        CustomVertical[]
  researchProjects ResearchProject[]
  researchRuns     ResearchRun[]
  researchSources  ResearchSource[]
  researchFindings ResearchFinding[]
  trendCandidates  TrendCandidate[]
  auditLogs        AuditLog[]
  invitations      Invitation[]
  trendWatchlists  TrendWatchlist[]
  campaigns        Campaign[]
  contentItems     ContentItem[]
  contentDrafts    ContentDraft[]
  audiencePersonas AudiencePersona[]
  contentPillars   ContentPillar[]
  topicIdeas       TopicIdea[]
  campaignBriefs   CampaignBrief[]
  scheduleEntries  ContentScheduleEntry[]
  mediaAssets      MediaAsset[]
  socialAccounts   SocialAccount[]

  @@map("organizations")
}

enum MembershipRole {
  ORG_OWNER
  ORG_ADMIN
  WORKSPACE_ADMIN
  RESEARCHER
  CONTENT_STRATEGIST
  CREATOR
  DESIGNER
  EDITOR
  APPROVER
  PUBLISHER
  ANALYST
  CLIENT_REVIEWER
  READ_ONLY
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
}

model Membership {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String           @db.Uuid
  userId           String           @db.Uuid
  role             MembershipRole
  /// Explicit permission grants beyond the role bundle (permission strings).
  extraPermissions String[]         @default([])
  /// Optional restriction to specific workspaces; empty = all in org.
  workspaceIds     String[]         @default([]) @db.Uuid
  status           MembershipStatus @default(ACTIVE)
  invitedById      String?          @db.Uuid

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("memberships")
}

/// Link-based invitation (no SMTP yet — the inviter shares the register
/// link; registering with the invited email joins automatically).
model Invitation {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String         @db.Uuid
  email          String
  role           MembershipRole @default(READ_ONLY)
  token          String         @unique
  invitedById    String?        @db.Uuid
  expiresAt      DateTime       @db.Timestamptz(6)
  acceptedAt     DateTime?      @db.Timestamptz(6)
  createdAt      DateTime       @default(now()) @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([email])
  @@map("invitations")
}

enum WorkspaceStatus {
  ACTIVE
  ARCHIVED
}

model Workspace {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String          @db.Uuid
  slug           String
  name           String
  description    String?
  /// Default display timezone for calendars; storage remains UTC.
  timezone       String          @default("UTC")
  settings       Json            @default("{}")
  status         WorkspaceStatus @default(ACTIVE)

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  organization     Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  brands           Brand[]
  verticals        CustomVertical[]
  researchProjects ResearchProject[]
  researchRuns     ResearchRun[]
  researchSources  ResearchSource[]
  researchFindings ResearchFinding[]
  trendCandidates  TrendCandidate[]
  trendWatchlists  TrendWatchlist[]
  campaigns        Campaign[]
  contentItems     ContentItem[]
  contentDrafts    ContentDraft[]
  audiencePersonas AudiencePersona[]
  contentPillars   ContentPillar[]
  topicIdeas       TopicIdea[]
  campaignBriefs   CampaignBrief[]
  scheduleEntries  ContentScheduleEntry[]
  mediaAssets      MediaAsset[]
  socialAccounts   SocialAccount[]

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@map("workspaces")
}

// ---------------------------------------------------------------------------
// Brand & custom vertical
// ---------------------------------------------------------------------------

enum BrandStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model Brand {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String      @db.Uuid
  workspaceId    String      @db.Uuid
  slug           String
  name           String
  description    String?
  websiteUrl     String?
  /// Brand voice: tone, personality, do-nots, example phrases.
  voice          Json?
  guidelines     Json        @default("{}")
  languages      String[]    @default([])
  status         BrandStatus @default(DRAFT)

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  researchProjects ResearchProject[]
  campaigns        Campaign[]
  contentItems     ContentItem[]

  @@unique([workspaceId, slug])
  @@index([organizationId])
  @@index([workspaceId, status])
  @@map("brands")
}

enum VerticalStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

/// Fully user-defined vertical. Industry fields are free text on purpose —
/// no hard-coded industry list. Structured collections live in typed JSONB
/// validated by @spectra/contracts customVerticalSchema at the API boundary.
model CustomVertical {
  id                       String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId           String         @db.Uuid
  workspaceId              String         @db.Uuid
  slug                     String
  name                     String
  description              String?
  industry                 String?
  subIndustry              String?
  businessModel            String?
  products                 String[]       @default([])
  services                 String[]       @default([])
  /// [{ name, description?, roles[], seniority? }]
  targetAudiences          Json           @default("[]")
  customerPainPoints       String[]       @default([])
  geographies              String[]       @default([])
  languages                String[]       @default([])
  /// [{ name, websiteUrl?, notes? }]
  competitors              Json           @default("[]")
  keywords                 String[]       @default([])
  excludedKeywords         String[]       @default([])
  trustedDomains           String[]       @default([])
  blockedDomains           String[]       @default([])
  preferredPublications    String[]       @default([])
  regulatoryConsiderations String[]       @default([])
  /// [{ name, startMonth?, endMonth?, notes? }]
  seasonalEvents           Json           @default("[]")
  commercialObjectives     String[]       @default([])
  contentObjectives        String[]       @default([])
  preferredPlatforms       String[]       @default([])
  /// [{ criterion, weight }] — brand-specific relevance criteria for scoring.
  relevanceCriteria        Json           @default("[]")
  status                   VerticalStatus @default(DRAFT)

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  researchProjects ResearchProject[]
  trendCandidates  TrendCandidate[]
  campaigns        Campaign[]
  contentItems     ContentItem[]

  @@unique([workspaceId, slug])
  @@index([organizationId])
  @@index([workspaceId, status])
  @@map("custom_verticals")
}

// ---------------------------------------------------------------------------
// Research
// ---------------------------------------------------------------------------

enum ResearchProjectStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

model ResearchProject {
  id                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId       String                @db.Uuid
  workspaceId          String                @db.Uuid
  verticalId           String?               @db.Uuid
  brandId              String?               @db.Uuid
  name                 String
  description          String?
  /// The user's research objective in their own words.
  objective            String?
  status               ResearchProjectStatus @default(DRAFT)
  createdById          String?               @db.Uuid
  /// Recurring-run cadence; null = manual runs only. The worker dispatcher
  /// reads these when the per-project scheduler fires.
  scheduleEveryMinutes Int?
  scheduleFeedUrls     String[]              @default([])

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  vertical     CustomVertical? @relation(fields: [verticalId], references: [id], onDelete: SetNull)
  brand        Brand?          @relation(fields: [brandId], references: [id], onDelete: SetNull)
  createdBy    User?           @relation("ResearchProjectCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  runs          ResearchRun[]
  sources       ResearchSource[]
  findings      ResearchFinding[]
  trends        TrendCandidate[]
  claims        ExtractedClaim[]
  citations     Citation[]
  evidencePacks EvidencePack[]

  @@index([workspaceId, status])
  @@index([organizationId])
  @@map("research_projects")
}

enum ResearchRunStatus {
  PENDING
  QUEUED
  RUNNING
  SUCCEEDED
  PARTIALLY_SUCCEEDED
  FAILED
  CANCELLED
}

enum ResearchRunTrigger {
  MANUAL
  SCHEDULED
  API
}

model ResearchRun {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String             @db.Uuid
  workspaceId    String             @db.Uuid
  projectId      String             @db.Uuid
  status         ResearchRunStatus  @default(PENDING)
  trigger        ResearchRunTrigger @default(MANUAL)
  /// Planned queries: [{ providerKind, queryText, language?, geography? }]
  queryPlan      Json               @default("[]")
  currentStage   String?
  startedAt      DateTime?          @db.Timestamptz(6)
  completedAt    DateTime?          @db.Timestamptz(6)
  failureReason  String?
  /// { queriesPlanned, sourcesDiscovered, findingsExtracted, ... }
  stats          Json               @default("{}")
  createdById    String?            @db.Uuid

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project      ResearchProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  sources  ResearchSource[]
  findings ResearchFinding[]

  @@index([projectId, status])
  @@index([workspaceId, status])
  @@map("research_runs")
}

enum SourceCategory {
  WEB
  NEWS
  BLOG
  ACADEMIC
  SOCIAL
  VIDEO
  PODCAST
  COMMUNITY
  DOCUMENT
  INTERNAL
  OTHER
}

enum SourceProcessingStatus {
  DISCOVERED
  FETCHED
  EXTRACTED
  NORMALIZED
  DEDUPLICATED
  ANALYZED
  FAILED
  SKIPPED
}

model ResearchSource {
  id                  String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId      String                 @db.Uuid
  workspaceId         String                 @db.Uuid
  projectId           String                 @db.Uuid
  runId               String?                @db.Uuid
  url                 String
  canonicalUrl        String?
  /// SHA-256 of the normalized URL — exact-duplicate detection per workspace.
  urlHash             String
  title               String?
  publisher           String?
  author              String?
  publishedAt         DateTime?              @db.Timestamptz(6)
  retrievedAt         DateTime               @db.Timestamptz(6)
  language            String?
  geography           String?
  category            SourceCategory         @default(WEB)
  credibilityScore    Float?
  freshnessScore      Float?
  duplicateOfSourceId String?                @db.Uuid
  duplicateClusterKey String?
  /// SHA-256 of extracted content — near-duplicate clustering input.
  contentHash         String?
  /// { license?, rightsHolder?, attributionRequired?, usageNotes? }
  copyright           Json?
  /// { providerId, providerKind, requestRef?, retrievedAt, pipelineVersion? }
  provenance          Json
  processingStatus    SourceProcessingStatus @default(DISCOVERED)
  metadata            Json                   @default("{}")

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project      ResearchProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  run          ResearchRun?     @relation(fields: [runId], references: [id], onDelete: SetNull)
  duplicateOf  ResearchSource?  @relation("SourceDuplicates", fields: [duplicateOfSourceId], references: [id], onDelete: SetNull)
  duplicates   ResearchSource[] @relation("SourceDuplicates")

  findings  ResearchFinding[]
  snapshots SourceSnapshot[]

  @@unique([workspaceId, urlHash])
  @@index([projectId, processingStatus])
  @@index([workspaceId, category])
  @@index([duplicateClusterKey])
  @@map("research_sources")
}

/// Immutable capture of a source at retrieval time. Raw bytes live in
/// tenant-scoped object storage under `storageKey`; the row is the index.
model SourceSnapshot {
  id               String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String                   @db.Uuid
  workspaceId      String                   @db.Uuid
  sourceId         String                   @db.Uuid
  retrievedAt      DateTime                 @db.Timestamptz(6)
  /// SHA-256 of the captured content.
  contentHash      String
  storageKey       String
  mimeType         String
  sizeBytes        Int
  extractionStatus SnapshotExtractionStatus @default(PENDING)
  createdAt        DateTime                 @default(now()) @db.Timestamptz(6)

  source   ResearchSource    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  findings ResearchFinding[]

  @@index([sourceId])
  @@index([workspaceId, contentHash])
  @@map("source_snapshots")
}

enum SnapshotExtractionStatus {
  PENDING
  EXTRACTED
  FAILED
}

enum FindingStatus {
  PENDING_REVIEW
  VALIDATED
  REJECTED
  STALE
}

model ResearchFinding {
  id                       String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId           String         @db.Uuid
  workspaceId              String         @db.Uuid
  projectId                String         @db.Uuid
  runId                    String?        @db.Uuid
  sourceId                 String         @db.Uuid
  snapshotId               String?        @db.Uuid
  summary                  String
  excerpt                  String?
  /// { startOffset?, endOffset?, selector?, page? }
  excerptLocation          Json?
  confidence               Float?
  credibilityScore         Float?
  freshnessScore           Float?
  language                 String?
  geography                String?
  duplicateClusterKey      String?
  sourceCategory           SourceCategory @default(WEB)
  topics                   String[]       @default([])
  entities                 String[]       @default([])
  corroboratedByFindingIds String[]       @default([]) @db.Uuid
  /// { license?, rightsHolder?, attributionRequired?, usageNotes? }
  copyright                Json?
  /// { providerId, providerKind, requestRef?, retrievedAt, pipelineVersion? }
  provenance               Json
  status                   FindingStatus  @default(PENDING_REVIEW)
  processingStage          String?

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project      ResearchProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  run          ResearchRun?    @relation(fields: [runId], references: [id], onDelete: SetNull)
  source       ResearchSource  @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  snapshot     SourceSnapshot? @relation(fields: [snapshotId], references: [id], onDelete: SetNull)
  citations    Citation[]

  @@index([projectId, status])
  @@index([sourceId])
  @@index([workspaceId, status])
  @@index([duplicateClusterKey])
  @@map("research_findings")
}

// ---------------------------------------------------------------------------
// Evidence layer: claims, citations, evidence packs, knowledge chunks
// ---------------------------------------------------------------------------

enum ClaimType {
  FACTUAL
  STATISTIC
  PREDICTION
  OPINION
  QUOTE
}

enum ClaimVerificationStatus {
  UNVERIFIED
  CORROBORATED
  DISPUTED
  VERIFIED
  REJECTED
}

/// Heuristically extracted claims (ADR-0016). One row per normalized claim
/// per project; corroboration = supported by ≥2 distinct sources.
model ExtractedClaim {
  id                   String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId       String                  @db.Uuid
  workspaceId          String                  @db.Uuid
  projectId            String                  @db.Uuid
  text                 String
  /// titleKey-normalized claim text — the per-project dedupe identity.
  normalizedKey        String
  claimType            ClaimType               @default(FACTUAL)
  verificationStatus   ClaimVerificationStatus @default(UNVERIFIED)
  supportingFindingIds String[]                @default([]) @db.Uuid
  /// Distinct sources backing the claim (drives corroboration).
  sourceCount          Int                     @default(1)
  confidence           Float?

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  project   ResearchProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  citations Citation[]

  @@unique([projectId, normalizedKey])
  @@index([workspaceId, verificationStatus])
  @@map("extracted_claims")
}

/// First-class citation: finding ↔ source (+snapshot) with a byte locator.
/// The audit anchor behind every statement (ADR-0011).
model Citation {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @db.Uuid
  workspaceId    String    @db.Uuid
  projectId      String    @db.Uuid
  findingId      String    @db.Uuid
  sourceId       String    @db.Uuid
  snapshotId     String?   @db.Uuid
  claimId        String?   @db.Uuid
  url            String
  title          String?
  publisher      String?
  publishedAt    DateTime? @db.Timestamptz(6)
  retrievedAt    DateTime  @db.Timestamptz(6)
  excerpt        String?
  startOffset    Int?
  endOffset      Int?
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)

  project ResearchProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  finding ResearchFinding @relation(fields: [findingId], references: [id], onDelete: Cascade)
  claim   ExtractedClaim? @relation(fields: [claimId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([findingId])
  @@index([claimId])
  @@map("citations")
}

enum EvidencePackStatus {
  DRAFT
  READY
  STALE
  ARCHIVED
}

/// Curated bundle of findings/claims/citations per trend topic — the input
/// contract for content generation (Phase 3).
model EvidencePack {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId       String             @db.Uuid
  workspaceId          String             @db.Uuid
  projectId            String             @db.Uuid
  trendCandidateId     String?            @db.Uuid
  topicKey             String
  title                String
  summary              String?
  status               EvidencePackStatus @default(DRAFT)
  findingIds           String[]           @default([]) @db.Uuid
  claimIds             String[]           @default([]) @db.Uuid
  citationIds          String[]           @default([]) @db.Uuid
  /// Forward lineage: which generated content consumed this pack.
  usedByContentItemIds String[]           @default([]) @db.Uuid

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  project ResearchProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, topicKey])
  @@index([workspaceId, status])
  @@map("evidence_packs")
}

/// Embedded knowledge chunks (pgvector, ADR-0005/0016). Phase 2 embeds
/// research findings (documentId = source id, metadata.kind marks it);
/// uploaded documents join in Phase 3. Vector ops via PgVectorStore raw SQL.
model DocumentChunk {
  id                String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId    String                      @db.Uuid
  workspaceId       String                      @db.Uuid
  /// Collection isolates embedding models — one model per collection.
  collection        String
  documentId        String                      @db.Uuid
  index             Int                         @default(0)
  text              String
  metadata          Json                        @default("{}")
  embeddingProvider String
  embeddingModel    String
  dimensions        Int
  embedding         Unsupported("vector(256)")?

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([organizationId, workspaceId, collection])
  @@index([documentId])
  @@map("document_chunks")
}

/// Keyword watchlist: fires SCORE_THRESHOLD alerts when a watched topic's
/// score first crosses the threshold in a run.
model TrendWatchlist {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @db.Uuid
  workspaceId    String   @db.Uuid
  name           String
  keywords       String[] @default([])
  threshold      Float    @default(0.7)
  createdById    String?  @db.Uuid

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("trend_watchlists")
}

enum TrendAlertType {
  STATE_CHANGE
  SCORE_THRESHOLD
  NEW_EVIDENCE
  RISK_FLAG
}

model TrendAlert {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String         @db.Uuid
  workspaceId      String         @db.Uuid
  trendCandidateId String         @db.Uuid
  alertType        TrendAlertType
  message          String
  triggeredAt      DateTime       @default(now()) @db.Timestamptz(6)
  acknowledgedAt   DateTime?      @db.Timestamptz(6)
  acknowledgedById String?        @db.Uuid

  trendCandidate TrendCandidate @relation(fields: [trendCandidateId], references: [id], onDelete: Cascade)

  @@index([workspaceId, acknowledgedAt])
  @@map("trend_alerts")
}

// ---------------------------------------------------------------------------
// Trend intelligence
// ---------------------------------------------------------------------------

enum TrendState {
  EMERGING
  ACCELERATING
  PEAKING
  STABLE
  DECLINING
  SEASONAL
  EVERGREEN
  UNVERIFIED
  REJECTED
}

model TrendCandidate {
  id                   String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId       String     @db.Uuid
  workspaceId          String     @db.Uuid
  projectId            String?    @db.Uuid
  verticalId           String?    @db.Uuid
  /// Stable identity for upserts within a project (e.g. normalized topic keyword).
  topicKey             String?
  title                String
  summary              String?
  state                TrendState @default(UNVERIFIED)
  /// Normalized [0,1] score from the latest scoring run.
  normalizedScore      Float?
  /// Full TrendScoreResult (components + explanation) — always explainable.
  latestScore          Json?
  scoringConfigId      String?
  scoringConfigVersion String?
  /// Trend signals referenced by this candidate.
  signals              Json       @default("[]")
  sourceIds            String[]   @default([]) @db.Uuid
  findingIds           String[]   @default([]) @db.Uuid
  firstSeenAt          DateTime?  @db.Timestamptz(6)
  lastSeenAt           DateTime?  @db.Timestamptz(6)

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project      ResearchProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  vertical     CustomVertical?  @relation(fields: [verticalId], references: [id], onDelete: SetNull)
  alerts       TrendAlert[]

  @@index([workspaceId, state])
  @@index([projectId, topicKey])
  @@index([workspaceId, normalizedScore])
  @@map("trend_candidates")
}

// ---------------------------------------------------------------------------
// Content strategy & generation (Phase 3)
// ---------------------------------------------------------------------------

enum CampaignStatus {
  DRAFT
  PLANNED
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum FunnelStage {
  AWARENESS
  CONSIDERATION
  CONVERSION
  RETENTION
  ADVOCACY
}

enum ContentType {
  POST
  ARTICLE
  THREAD
  VIDEO_SCRIPT
  IMAGE
  CAROUSEL
  SHORT_VIDEO
  LONG_VIDEO
  AUDIO
  EMAIL
  OTHER
}

/// Mirrors CONTENT_LIFECYCLE_STATES in @spectra/contracts — never scattered strings.
enum ContentLifecycleState {
  IDEA
  RESEARCHING
  RESEARCH_READY
  BRIEF
  STRATEGY
  DRAFT
  GENERATED
  EDITING
  REVIEW
  CHANGES_REQUESTED
  APPROVED
  SCHEDULED
  PUBLISHING
  PUBLISHED
  PARTIALLY_PUBLISHED
  FAILED
  ARCHIVED
}

model Campaign {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String         @db.Uuid
  workspaceId    String         @db.Uuid
  brandId        String?        @db.Uuid
  verticalId     String?        @db.Uuid
  name           String
  description    String?
  status         CampaignStatus @default(DRAFT)
  /// Display timezone for planning; storage remains UTC.
  timezone       String         @default("UTC")
  startAt        DateTime?      @db.Timestamptz(6)
  endAt          DateTime?      @db.Timestamptz(6)
  createdById    String?        @db.Uuid

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  vertical     CustomVertical? @relation(fields: [verticalId], references: [id], onDelete: SetNull)
  brand        Brand?          @relation(fields: [brandId], references: [id], onDelete: SetNull)
  contentItems ContentItem[]
  brief        CampaignBrief?

  @@index([workspaceId, status])
  @@map("campaigns")
}

/// A durable content object. Every item can be traced to the evidence pack,
/// citations and findings it was grounded on, plus each generation attempt.
model ContentItem {
  id                String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId    String                @db.Uuid
  workspaceId       String                @db.Uuid
  campaignId        String?               @db.Uuid
  brandId           String?               @db.Uuid
  verticalId        String?               @db.Uuid
  title             String
  contentType       ContentType           @default(POST)
  lifecycleState    ContentLifecycleState @default(IDEA)
  funnelStage       FunnelStage?
  /// The operator's objective for this piece, in their own words (trusted).
  objective         String?
  /// Current best body (latest accepted draft, or human edit).
  body              String?
  /// Human edit history (HumanEditRecord[]) and approval decisions (ApprovalRecord[]).
  humanEdits        Json                  @default("[]")
  approvals         Json                  @default("[]")
  /// Latest moderation verdict; null = never moderated.
  moderation        Json?
  /// Grounding lineage — which evidence this item draws on. Never fabricated.
  evidencePackId    String?               @db.Uuid
  researchProjectId String?               @db.Uuid
  topicKey          String?
  findingIds        String[]              @default([]) @db.Uuid
  citationIds       String[]              @default([]) @db.Uuid
  createdById       String?               @db.Uuid

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  organization    Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace       Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign        Campaign?              @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  brand           Brand?                 @relation(fields: [brandId], references: [id], onDelete: SetNull)
  vertical        CustomVertical?        @relation(fields: [verticalId], references: [id], onDelete: SetNull)
  drafts          ContentDraft[]
  scheduleEntries ContentScheduleEntry[]

  @@index([workspaceId, lifecycleState])
  @@index([campaignId])
  @@map("content_items")
}

enum ContentDraftStatus {
  GENERATING
  READY
  FAILED
}

/// One AI generation attempt. Records the exact citations/findings supplied as
/// grounding plus the model and prompt version — outputs are attributable and
/// regressions bisectable. Citations here are the ones the draft was grounded
/// on, never fabricated post-hoc.
model ContentDraft {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId     String             @db.Uuid
  workspaceId        String             @db.Uuid
  contentItemId      String             @db.Uuid
  status             ContentDraftStatus @default(GENERATING)
  body               String?
  /// Grounding actually supplied to the model for THIS draft.
  evidencePackId     String?            @db.Uuid
  citationIds        String[]           @default([]) @db.Uuid
  findingIds         String[]           @default([]) @db.Uuid
  /// Generation record — versioned for attribution (GenerationRecord contract).
  modelProvider      String?
  modelName          String?
  modelVersion       String?
  promptTemplateId   String?
  promptVersion      String?
  usageInputTokens   Int?
  usageOutputTokens  Int?
  finishReason       String?
  failureReason      String?
  /// CitationValidation — which [n] markers map to supplied sources vs dangling.
  citationValidation Json?
  createdById        String?            @db.Uuid

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contentItem  ContentItem  @relation(fields: [contentItemId], references: [id], onDelete: Cascade)

  @@index([contentItemId, createdAt])
  @@map("content_drafts")
}

// ---------------------------------------------------------------------------
// Strategy entities (Phase 3C)
// ---------------------------------------------------------------------------

model AudiencePersona {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId     String   @db.Uuid
  workspaceId        String   @db.Uuid
  name               String
  description        String?
  roles              String[] @default([])
  seniority          String?
  industries         String[] @default([])
  painPoints         String[] @default([])
  goals              String[] @default([])
  preferredPlatforms String[] @default([])
  languages          String[] @default([])
  createdById        String?  @db.Uuid

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("audience_personas")
}

model ContentPillar {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @db.Uuid
  workspaceId    String   @db.Uuid
  /// Optional brand association (plain column — no FK, mirrors ContentItem lineage).
  brandId        String?  @db.Uuid
  name           String
  description    String?
  keywords       String[] @default([])
  createdById    String?  @db.Uuid

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("content_pillars")
}

enum TopicIdeaStatus {
  PROPOSED
  SHORTLISTED
  IN_USE
  DISCARDED
}

/// A candidate topic, optionally traceable to the research it came from.
model TopicIdea {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId    String          @db.Uuid
  workspaceId       String          @db.Uuid
  title             String
  description       String?
  pillarId          String?         @db.Uuid
  verticalId        String?         @db.Uuid
  status            TopicIdeaStatus @default(PROPOSED)
  /// Research lineage (plain columns) — where the idea is grounded.
  evidencePackId    String?         @db.Uuid
  findingIds        String[]        @default([]) @db.Uuid
  trendCandidateIds String[]        @default([]) @db.Uuid
  citationIds       String[]        @default([]) @db.Uuid
  createdById       String?         @db.Uuid

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@map("topic_ideas")
}

/// One brief per campaign — background, objectives, mandatories and do-nots.
model CampaignBrief {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @db.Uuid
  workspaceId    String   @db.Uuid
  campaignId     String   @unique @db.Uuid
  background     String?
  objectives     String[] @default([])
  keyMessages    String[] @default([])
  mandatories    String[] @default([])
  doNots         String[] @default([])
  tone           String?
  createdById    String?  @db.Uuid

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign     Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("campaign_briefs")
}

// ---------------------------------------------------------------------------
// Content calendar & scheduling (Phase 3E)
// ---------------------------------------------------------------------------

enum ScheduleEntryStatus {
  SCHEDULED
  QUEUED
  PUBLISHING
  PUBLISHED
  FAILED
  // No live publisher wired for the platform — honest terminal state, not a failure.
  UNSUPPORTED
  CANCELLED
}

/// One scheduled placement of a content item on a platform at a UTC instant.
/// Publishing itself arrives in Phase 4; entries stay SCHEDULED until then.
model ContentScheduleEntry {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String              @db.Uuid
  workspaceId     String              @db.Uuid
  contentItemId   String              @db.Uuid
  /// Optional publishing target; when set, the dispatcher attempts to publish.
  socialAccountId String?             @db.Uuid
  /// Social platform label (validated against socialPlatformSchema at the API).
  platform        String
  /// UTC instant; rendered in the workspace/calendar display timezone.
  scheduledAt     DateTime            @db.Timestamptz(6)
  status          ScheduleEntryStatus @default(SCHEDULED)
  note            String?
  /// Publish idempotency key — dispatching the same entry twice is safe.
  idempotencyKey  String?             @unique
  attemptCount    Int                 @default(0)
  lastAttemptAt   DateTime?           @db.Timestamptz(6)
  failureReason   String?
  externalPostId  String?
  externalUrl     String?
  publishedAt     DateTime?           @db.Timestamptz(6)
  createdById     String?             @db.Uuid

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contentItem  ContentItem  @relation(fields: [contentItemId], references: [id], onDelete: Cascade)

  @@index([workspaceId, scheduledAt])
  @@index([contentItemId])
  @@index([status, scheduledAt])
  @@map("content_schedule_entries")
}

// ---------------------------------------------------------------------------
// Media assets (Phase 3F)
// ---------------------------------------------------------------------------

enum MediaKind {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  OTHER
}

/// A media asset in tenant-rooted object storage. Phase 3F wires real image
/// rendering (sharp); video/audio remain honestly unavailable until ffmpeg.
model MediaAsset {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @db.Uuid
  workspaceId    String    @db.Uuid
  kind           MediaKind @default(IMAGE)
  /// Tenant-rooted object storage key (org/<id>/ws/<id>/renders|media/…).
  storageKey     String
  mimeType       String
  sizeBytes      Int
  widthPx        Int?
  heightPx       Int?
  durationMs     Int?
  checksum       String?
  /// The asset this was derived from (e.g. the uploaded source image).
  sourceAssetId  String?   @db.Uuid
  /// Rendering engine that produced it (e.g. "sharp").
  engine         String?
  createdById    String?   @db.Uuid

  createdAt DateTime @default(now()) @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@map("media_assets")
}

// ---------------------------------------------------------------------------
// Publishing — social accounts (Phase 4)
// ---------------------------------------------------------------------------

enum SocialPlatform {
  LINKEDIN
  INSTAGRAM
  FACEBOOK
  YOUTUBE
  TIKTOK
  THREADS
  X
  PINTEREST
  WORDPRESS
  EMAIL
}

/// PENDING = registered target, not yet OAuth-verified (no live adapter wired).
enum SocialAccountStatus {
  PENDING
  CONNECTED
  EXPIRED
  REVOKED
  ERROR
}

enum SocialAccountKind {
  PROFILE
  PAGE
  CHANNEL
  BUSINESS_ACCOUNT
  SITE
}

/// A publishing target. Any stored credential lives ONLY in `encryptedToken`
/// (AES-256-GCM via @spectra/security) and is NEVER returned by the API;
/// `tokenRef` is an opaque handle. No live platform is wired in Phase 4A —
/// accounts stay PENDING until an adapter verifies them.
model SocialAccount {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId    String              @db.Uuid
  workspaceId       String              @db.Uuid
  platform          SocialPlatform
  externalAccountId String
  displayName       String
  kind              SocialAccountKind   @default(PROFILE)
  status            SocialAccountStatus @default(PENDING)
  scopes            String[]            @default([])
  /// Opaque reference to the sealed credential; never the raw token.
  tokenRef          String?
  /// AES-256-GCM sealed credential. NEVER selected into API responses.
  encryptedToken    String?
  connectedById     String?             @db.Uuid
  connectedAt       DateTime            @default(now()) @db.Timestamptz(6)
  lastRefreshedAt   DateTime?           @db.Timestamptz(6)

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, platform])
  @@map("social_accounts")
}

// ---------------------------------------------------------------------------
// Audit
// ---------------------------------------------------------------------------

enum AuditActorType {
  USER
  SYSTEM
  API_CLIENT
}

/// Append-only. Never updated, never soft-deleted. Sensitive values must be
/// redacted by @spectra/security deepRedact before insertion.
model AuditLog {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String         @db.Uuid
  workspaceId    String?        @db.Uuid
  actorType      AuditActorType @default(USER)
  actorUserId    String?        @db.Uuid
  action         String
  resourceType   String
  resourceId     String?
  correlationId  String?
  ip             String?
  userAgent      String?
  changes        Json?
  metadata       Json           @default("{}")
  createdAt      DateTime       @default(now()) @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUser    User?        @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([resourceType, resourceId])
  @@index([correlationId])
  @@map("audit_logs")
}
