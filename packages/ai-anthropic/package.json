{
  "name": "@spectra/ai-anthropic",
  "version": "0.1.0",
  "private": true,
  "description": "Anthropic Claude adapter implementing the @spectra/ai-core TextGenerationProvider port. Env-gated: unconfigured means honestly unavailable, never fabricated output.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
